// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  username    String   @unique
  password    String
  gender      Gender
  firstName   String
  lastName    String
  dob         DateTime
  accessToken String   @default("")

  channelName    String @default("")
  banner         String @default("")
  profilePicture String @default("")
  description    String @default("")

  subscriberCount Int       @default(0)
  deleted         Boolean   @default(false)
  uploads         Uploads[]

  subscriptions Subscription[] @relation("UserSubscriptions")
  subscribers   Subscription[] @relation("ChannelSubscribers")
  liked         Like[]         @relation("UserLikes")
}

model Subscription {
  id           String   @id @default(uuid())
  channelId    String
  subscriberId String
  createdAt    DateTime @default(now())

  subscriber User @relation("UserSubscriptions", fields: [subscriberId], references: [id], onDelete: Cascade)
  channel    User @relation("ChannelSubscribers", fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, channelId])
  @@index([channelId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  createdAt DateTime @default(now())

  likedBy    User    @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  likedVideo Uploads @relation("LikedBy", fields: [videoId], references: [id], onDelete: Cascade)

  @@unique([userId, videoId])
  @@index([videoId])
}

model Uploads {
  id String @id @default(uuid())

  title       String
  description String

  slug String @unique

  videoUrl     String
  thumbnailUrl String

  views Int @default(0)
  like  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDraft   Boolean  @default(false)

  userId String
  user   User   @relation(fields: [userId], references: [id])

  likedBy Like[] @relation("LikedBy")
}

enum Gender {
  Male
  Female
  Other
}
